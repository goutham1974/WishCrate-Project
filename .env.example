# Database Configuration
DB_URL=jdbc:mysql://localhost:3306/wishcrate_db?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=root

# Server Configuration
PORT=8080

# JWT Configuration
JWT_SECRET=YourLongSecureJWTSecretKeyHere-Generate-Random-Hex-String

# Email Configuration (Gmail)
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-specific-password

# Stripe Configuration (Optional)
STRIPE_API_KEY=sk_test_your_stripe_test_key

# AWS Configuration (Optional)
AWS_ACCESS_KEY=your_aws_access_key
AWS_SECRET_KEY=your_aws_secret_key
AWS_S3_BUCKET=wishcrate-images
AWS_REGION=us-east-1

# Frontend API URL (for production)
VITE_API_URL=http://localhost:8080

# Application Environment
SPRING_PROFILES_ACTIVE=dev
